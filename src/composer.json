{
  "name": "techzeeland/tzldashy",
  "description": "TZLDashy — A self-hosted server dashboard",
  "license": "AGPL-3.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  }
}
