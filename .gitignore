# ─────────────────────────────────────────────────────────────
#  TZLDashy .gitignore
# ─────────────────────────────────────────────────────────────

# ── Environment & credentials (NEVER commit these) ────────────
.env
*.env.local
*.env.*.local
secrets/

# ── Composer / PHP dependencies ───────────────────────────────
src/vendor/
composer.phar

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
src/logs/

# ── User-uploaded content (stored in Docker volumes) ──────────
src/public/Logos/*
src/public/uploads/*
# Keep the directories themselves
!src/public/Logos/.gitkeep
!src/public/uploads/.gitkeep
!src/public/uploads/avatars/.gitkeep

# ── OS / Editor junk ──────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ── Docker local override files ───────────────────────────────
docker-compose.override.yml
docker-compose.local.yml

# ── Build artifacts ───────────────────────────────────────────
*.tmp
*.bak
*.orig
