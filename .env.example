# ─────────────────────────────────────────────────────────────
#  TZLDashy — Local Development Environment
#
#  This file is the TEMPLATE.  Copy it to .env and fill in
#  your values for local development ONLY.
#
#  cp .env.example .env
#
#  NEVER commit .env — it is in .gitignore.
#  In production (Docker / Portainer) all variables are set
#  directly inside docker-compose.yml, not via .env.
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_NAME=TZLDashy
APP_ENV=development
APP_KEY=your-random-32-character-key-here
APP_URL=http://localhost:1011
SESSION_NAME=tzldashy_session
SESSION_LIFETIME=86400

# ── Database ──────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=tzldashy
DB_USER=tzldashy
DB_PASS=your_db_password_here
MYSQL_ROOT_PASSWORD=your_root_password_here

# ── SMTP ──────────────────────────────────────────────────────
# In production, the official TZLDashy SMTP is pre-configured
# in docker-compose.yml.  For local dev, fill these in or
# use a service like Mailtrap.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_ENCRYPTION=ssl
SMTP_USER=your@email.com
SMTP_PASS=your_smtp_password
SMTP_FROM=your@email.com
SMTP_FROM_NAME=TZLDashy
