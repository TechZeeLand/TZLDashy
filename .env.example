# ─────────────────────────────────────────────────────────────
#  TZLDashy — Local Development Environment
#
#  Copy to .env and fill in your values for local dev ONLY.
#    cp .env.example .env
#
#  NEVER commit .env — it is in .gitignore.
#  In production, all variables are set inside docker-compose.yml.
# ─────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────
APP_NAME=TZLDashy
APP_ENV=development
APP_KEY=your-random-32-character-key-here
APP_URL=http://localhost:1011
SESSION_NAME=tzldashy_session
SESSION_LIFETIME=86400

# ── Database ──────────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=tzldashy
DB_USER=tzldashy
DB_PASS=your_db_password_here
